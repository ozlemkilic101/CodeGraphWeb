@model CodeGraphWeb.ViewModels.Company.CreateCompanyInputModel
@{
    ViewData["Title"] = "Create Company";
}

<div class="max-w-3xl space-y-6">
    <div>
        <h3 class="text-3xl font-black tracking-tight">Create Company</h3>
        <p class="text-on-surface-variant">Yeni tenant sirketini veritabanina kaydet.</p>
    </div>

    <form asp-controller="Company" asp-action="Create" method="post" class="bg-surface-container-low rounded-xl border border-outline-variant/10 overflow-hidden">
        @Html.AntiForgeryToken()
        <div class="p-8 space-y-5">
            <div class="space-y-2">
                <label asp-for="Name" class="text-[13px] font-semibold text-on-surface-variant ml-1"></label>
                <input asp-for="Name" class="w-full bg-surface-container-highest border-none rounded-lg px-4 py-3 text-on-surface focus:ring-2 focus:ring-primary/50" placeholder="e.g. AIZOF" />
                <span asp-validation-for="Name" class="text-red-300 text-xs"></span>
            </div>
        </div>
        <div class="p-6 bg-surface-container-highest/30 border-t border-outline-variant/10 flex justify-end gap-2">
            <a asp-controller="Company" asp-action="Index" class="px-6 py-3 text-sm font-bold text-on-surface-variant hover:text-on-surface">Cancel</a>
            <button type="submit" class="bg-gradient-to-br from-primary-container to-primary px-8 py-3 rounded-lg text-on-primary font-bold shadow-lg shadow-primary/20">
                Create Company
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
