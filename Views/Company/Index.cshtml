@{
    ViewData["Title"] = "Companies";
}

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h3 class="text-3xl font-black tracking-tight">Companies</h3>
            <p class="text-on-surface-variant">Manage organizations and their active analysis pipelines.</p>
        </div>
        <a href="/Company/Create" class="bg-gradient-to-br from-primary-container to-primary px-6 py-3 rounded-lg text-on-primary font-bold shadow-lg shadow-primary/20">
            New Company
        </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <article class="bg-surface-container rounded-xl p-6 border border-white/5 space-y-2">
            <h4 class="text-lg font-bold">Nova Systems</h4>
            <p class="text-sm text-on-surface-variant">Projects: 8</p>
            <p class="text-sm text-on-surface-variant">Members: 26</p>
        </article>
        <article class="bg-surface-container rounded-xl p-6 border border-white/5 space-y-2">
            <h4 class="text-lg font-bold">Artemis Labs</h4>
            <p class="text-sm text-on-surface-variant">Projects: 5</p>
            <p class="text-sm text-on-surface-variant">Members: 14</p>
        </article>
        <article class="bg-surface-container rounded-xl p-6 border border-white/5 space-y-2">
            <h4 class="text-lg font-bold">Pioneer Cloud</h4>
            <p class="text-sm text-on-surface-variant">Projects: 3</p>
            <p class="text-sm text-on-surface-variant">Members: 11</p>
        </article>
    </div>
</div>
