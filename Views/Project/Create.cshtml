@model CodeGraphWeb.ViewModels.Project.ProjectCreatePageViewModel
@{
    ViewData["Title"] = "Create Project";
}

<div class="space-y-8">
    <div>
        <h3 class="text-3xl font-black tracking-tight mb-2">Create New Project</h3>
        <p class="text-on-surface-variant">Sikistirilmis proje dosyasi yukleyerek proje olusturun.</p>
    </div>

    <form asp-controller="Project" asp-action="Create" method="post" enctype="multipart/form-data" class="bg-surface-container-low rounded-xl border border-outline-variant/10 shadow-2xl overflow-hidden">
        @Html.AntiForgeryToken()
        <div class="p-8 space-y-8">
            <section class="space-y-6">
                <h4 class="text-sm font-bold uppercase tracking-widest text-on-surface-variant">General Information</h4>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-2">
                        <label asp-for="Input.ProjectName" class="text-[13px] font-semibold text-on-surface-variant ml-1">Project Name</label>
                        <input asp-for="Input.ProjectName" class="w-full bg-surface-container-highest border-none rounded-lg px-4 py-3 text-on-surface focus:ring-2 focus:ring-primary/50" />
                        <span asp-validation-for="Input.ProjectName" class="text-red-300 text-xs"></span>
                    </div>
                    <div class="space-y-2">
                        <label asp-for="Input.CompanyId" class="text-[13px] font-semibold text-on-surface-variant ml-1">Company</label>
                        <select asp-for="Input.CompanyId" id="company-select" class="w-full bg-surface-container-highest border-none rounded-lg px-4 py-3 text-on-surface focus:ring-2 focus:ring-primary/50">
                            @foreach (var company in Model.Companies)
                            {
                                <option value="@company.Id">@company.Name</option>
                            }
                        </select>
                        <span asp-validation-for="Input.CompanyId" class="text-red-300 text-xs"></span>
                    </div>
                </div>
                <div class="space-y-2">
                    <label asp-for="Input.Description" class="text-[13px] font-semibold text-on-surface-variant ml-1">Description</label>
                    <textarea asp-for="Input.Description" rows="4" class="w-full bg-surface-container-highest border-none rounded-lg px-4 py-3 text-on-surface focus:ring-2 focus:ring-primary/50"></textarea>
                    <span asp-validation-for="Input.Description" class="text-red-300 text-xs"></span>
                </div>
            </section>

            <section class="space-y-4">
                <h4 class="text-sm font-bold uppercase tracking-widest text-on-surface-variant">Project File Upload</h4>
                <p class="text-xs text-on-surface-variant">Sadece .zip, .tar, .rar dosyalari, maksimum 50MB.</p>

                <input asp-for="Input.File" id="project-file-input" type="file" accept=".zip,.tar,.rar" class="hidden" />
                <div id="drop-zone" class="w-full border-2 border-dashed border-outline-variant/30 rounded-xl py-10 px-6 bg-surface-container-lowest/50 text-center cursor-pointer hover:border-primary/50 transition-colors">
                    <span class="material-symbols-outlined text-primary text-3xl">upload_file</span>
                    <p class="text-on-surface font-semibold mt-3">Drag and drop project archive here</p>
                    <p class="text-on-surface-variant text-sm mt-1">or click to select file</p>
                    <button id="file-picker-btn" type="button" class="mt-4 bg-surface-container-high text-on-surface px-4 py-2 rounded-md text-sm font-semibold">Choose File</button>
                    <p id="selected-file-name" class="mt-3 text-xs text-on-surface-variant">No file selected</p>
                </div>
                <span asp-validation-for="Input.File" class="text-red-300 text-xs"></span>
            </section>

            <section class="space-y-4">
                <h4 class="text-sm font-bold uppercase tracking-widest text-on-surface-variant">Team Assignment</h4>
                <p class="text-xs text-on-surface-variant">Sirket secimine gore kullanicilar DB'den yuklenir.</p>
                <div id="users-loading" class="hidden text-xs text-on-surface-variant">Yukleniyor...</div>
                <div id="users-empty" class="hidden text-xs text-on-surface-variant">Bu sirkette kullanici bulunamadi.</div>
                <div id="users-container" class="grid grid-cols-1 md:grid-cols-2 gap-3">
                    @foreach (var user in Model.Users)
                    {
                        <label class="bg-surface-container-high rounded-md px-3 py-3 flex items-center gap-3">
                            @if (Model.Input.AssignedUserIds.Contains(user.Id))
                            {
                                <input type="checkbox" name="Input.AssignedUserIds" value="@user.Id" checked class="rounded border-white/20 bg-surface-container-highest" />
                            }
                            else
                            {
                                <input type="checkbox" name="Input.AssignedUserIds" value="@user.Id" class="rounded border-white/20 bg-surface-container-highest" />
                            }
                            <span class="text-sm">
                                <span class="font-semibold">@user.FullName</span>
                                <span class="text-on-surface-variant text-xs block">@user.Email</span>
                            </span>
                        </label>
                    }
                </div>
            </section>
        </div>

        <div class="p-8 bg-surface-container-highest/30 flex items-center justify-between border-t border-outline-variant/10">
            <a asp-controller="Project" asp-action="Index" class="px-6 py-3 text-sm font-bold text-on-surface-variant hover:text-on-surface">Cancel</a>
            <button id="create-project-submit" type="submit" class="bg-gradient-to-br from-primary-container to-primary px-8 py-3 rounded-lg text-on-primary font-bold shadow-lg shadow-primary/20 disabled:opacity-50 disabled:cursor-not-allowed" disabled>
                Create Project
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const companySelect = document.getElementById('company-select');
        const usersContainer = document.getElementById('users-container');
        const usersLoading = document.getElementById('users-loading');
        const usersEmpty = document.getElementById('users-empty');
        const fileInput = document.getElementById('project-file-input');
        const dropZone = document.getElementById('drop-zone');
        const filePickerBtn = document.getElementById('file-picker-btn');
        const selectedFileName = document.getElementById('selected-file-name');
        const submitBtn = document.getElementById('create-project-submit');

        function updateFileState(file) {
            if (file) {
                selectedFileName.textContent = `${file.name} (${Math.ceil(file.size / 1024)} KB)`;
                submitBtn.disabled = false;
            } else {
                selectedFileName.textContent = 'No file selected';
                submitBtn.disabled = true;
            }
        }

        filePickerBtn.addEventListener('click', () => fileInput.click());

        dropZone.addEventListener('click', () => fileInput.click());
        dropZone.addEventListener('dragover', (event) => {
            event.preventDefault();
            dropZone.classList.add('border-primary');
        });
        dropZone.addEventListener('dragleave', () => {
            dropZone.classList.remove('border-primary');
        });
        dropZone.addEventListener('drop', (event) => {
            event.preventDefault();
            dropZone.classList.remove('border-primary');

            const files = event.dataTransfer.files;
            if (!files || files.length === 0) {
                updateFileState(null);
                return;
            }

            fileInput.files = files;
            updateFileState(files[0]);
        });

        fileInput.addEventListener('change', (event) => {
            const file = event.target.files && event.target.files.length > 0
                ? event.target.files[0]
                : null;
            updateFileState(file);
        });

        async function loadUsers(companyId) {
            usersLoading.classList.remove('hidden');
            usersEmpty.classList.add('hidden');

            try {
                const response = await fetch(`/Project/CompanyUsers?companyId=${companyId}`);
                if (!response.ok) {
                    usersContainer.innerHTML = '';
                    usersEmpty.classList.remove('hidden');
                    return;
                }

                const users = await response.json();
                usersContainer.innerHTML = '';

                if (!users || users.length === 0) {
                    usersEmpty.classList.remove('hidden');
                    return;
                }

                users.forEach((user) => {
                    const wrapper = document.createElement('label');
                    wrapper.className = 'bg-surface-container-high rounded-md px-3 py-3 flex items-center gap-3';
                    wrapper.innerHTML = `
                        <input type="checkbox" name="Input.AssignedUserIds" value="${user.id}" class="rounded border-white/20 bg-surface-container-highest" />
                        <span class="text-sm">
                            <span class="font-semibold">${user.fullName}</span>
                            <span class="text-on-surface-variant text-xs block">${user.email}</span>
                        </span>
                    `;
                    usersContainer.appendChild(wrapper);
                });
            } finally {
                usersLoading.classList.add('hidden');
            }
        }

        if (companySelect) {
            companySelect.addEventListener('change', (event) => {
                loadUsers(event.target.value);
            });
        }
    </script>
}
