@{
    ViewData["Title"] = "Create Project";
}

<div class="space-y-8">
    <div>
        <h3 class="text-3xl font-black tracking-tight mb-2">Create New Project</h3>
        <p class="text-on-surface-variant">Initialize a new dependency analysis and vulnerability mapping session.</p>
    </div>

    <form class="bg-surface-container-low rounded-xl border border-outline-variant/10 shadow-2xl overflow-hidden">
        <div class="p-8 space-y-8">
            <section class="space-y-6">
                <h4 class="text-sm font-bold uppercase tracking-widest text-on-surface-variant">General Information</h4>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-2">
                        <label class="text-[13px] font-semibold text-on-surface-variant ml-1">Project Name</label>
                        <input class="w-full bg-surface-container-highest border-none rounded-lg px-4 py-3 text-on-surface focus:ring-2 focus:ring-primary/50" placeholder="e.g. Apollo-Services-API" type="text" />
                    </div>
                    <div class="space-y-2">
                        <label class="text-[13px] font-semibold text-on-surface-variant ml-1">Technology Stack</label>
                        <select class="w-full bg-surface-container-highest border-none rounded-lg px-4 py-3 text-on-surface focus:ring-2 focus:ring-primary/50">
                            <option value="">Select Platform</option>
                            <option>.NET Core / C#</option>
                            <option>Android / Kotlin</option>
                            <option>Node.js / TypeScript</option>
                            <option>Python / Django</option>
                        </select>
                    </div>
                </div>
                <div class="space-y-2">
                    <label class="text-[13px] font-semibold text-on-surface-variant ml-1">Description</label>
                    <textarea class="w-full bg-surface-container-highest border-none rounded-lg px-4 py-3 text-on-surface focus:ring-2 focus:ring-primary/50" rows="4" placeholder="Briefly describe the project scope and architecture goals..."></textarea>
                </div>
            </section>

            <section class="space-y-4">
                <h4 class="text-sm font-bold uppercase tracking-widest text-on-surface-variant">Configuration Files</h4>
                <div class="w-full border-2 border-dashed border-outline-variant/30 rounded-xl py-12 flex flex-col items-center justify-center bg-surface-container-lowest/50">
                    <span class="material-symbols-outlined text-primary text-3xl">upload_file</span>
                    <p class="text-on-surface font-semibold mt-3">Drop project config files here</p>
                    <p class="text-on-surface-variant text-sm mt-1">Accepts package.json, csproj, pom.xml, requirements.txt</p>
                </div>
            </section>
        </div>

        <div class="p-8 bg-surface-container-highest/30 flex items-center justify-between border-t border-outline-variant/10">
            <a href="/Project" class="px-6 py-3 text-sm font-bold text-on-surface-variant hover:text-on-surface">Discard Draft</a>
            <button class="bg-gradient-to-br from-primary-container to-primary px-8 py-3 rounded-lg text-on-primary font-bold shadow-lg shadow-primary/20">
                Analyze Project
            </button>
        </div>
    </form>
</div>
