@model CodeGraphWeb.ViewModels.Project.ProjectIndexViewModel
@{
    ViewData["Title"] = "Projects";
}

<section class="space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h3 class="text-3xl font-black tracking-tight">Projects</h3>
            <p class="text-on-surface-variant">Tüm proje listesi veritabanindan role/tenant filtresi ile gelir.</p>
        </div>

        @if (Model.CanCreateProject)
        {
            <a asp-controller="Project" asp-action="Create" class="bg-gradient-to-br from-primary-container to-primary px-6 py-3 rounded-lg text-on-primary font-bold shadow-lg shadow-primary/20">
                New Project
            </a>
        }
    </div>

    @if (TempData["ProjectSuccess"] is string projectSuccess)
    {
        <div class="rounded-lg border border-emerald-400/30 bg-emerald-400/10 text-emerald-200 px-4 py-3 text-sm">@projectSuccess</div>
    }

    @if (Model.Projects.Count == 0)
    {
        <div class="bg-surface-container rounded-xl border border-white/10 p-6 text-sm text-on-surface-variant">
            Gosterilecek proje yok.
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            @foreach (var project in Model.Projects)
            {
                <article class="bg-surface-container rounded-xl p-6 border border-white/10 space-y-3">
                    <div class="flex items-center justify-between">
                        <h4 class="text-lg font-bold">@project.Name</h4>
                        <span class="text-xs text-on-surface-variant">@project.CompanyName</span>
                    </div>
                    <p class="text-sm text-on-surface-variant">@(string.IsNullOrWhiteSpace(project.Description) ? "Aciklama yok" : project.Description)</p>
                    <p class="text-xs text-on-surface-variant">Members: @project.MemberCount · Created: @project.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</p>
                    <a asp-controller="Project" asp-action="Detail" asp-route-id="@project.Id" class="text-sm font-semibold text-primary">Open detail</a>
                </article>
            }
        </div>
    }
</section>
