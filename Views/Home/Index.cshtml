@{
    Layout = null;
}
<!DOCTYPE html>
<html class="dark" lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CodeGraph | Ana Sayfa</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "surface-container-lowest": "#0c0e14",
                        "error-container": "#93000a",
                        "on-error-container": "#ffdad6",
                        "tertiary-fixed": "#ffdcbf",
                        "on-tertiary-fixed-variant": "#6a3b00",
                        "tertiary-container": "#d37b02",
                        "background": "#111319",
                        "secondary": "#b2c7f5",
                        "primary-fixed-dim": "#acc7ff",
                        "surface-container-low": "#191b22",
                        "surface-container-high": "#282a30",
                        "on-secondary-fixed": "#011a3f",
                        "tertiary": "#ffb873",
                        "on-surface": "#e2e2eb",
                        "inverse-on-surface": "#2e3037",
                        "inverse-surface": "#e2e2eb",
                        "surface-bright": "#373940",
                        "secondary-fixed-dim": "#b2c7f5",
                        "primary": "#acc7ff",
                        "on-secondary-fixed-variant": "#32476d",
                        "surface": "#111319",
                        "error": "#ffb4ab",
                        "on-primary-container": "#00285b",
                        "tertiary-fixed-dim": "#ffb873",
                        "on-tertiary-container": "#412200",
                        "on-primary-fixed": "#001a40",
                        "on-primary": "#002f68",
                        "secondary-container": "#344970",
                        "secondary-fixed": "#d7e2ff",
                        "surface-container": "#1e1f26",
                        "on-tertiary": "#4b2800",
                        "outline": "#8c909e",
                        "on-surface-variant": "#c2c6d5",
                        "primary-fixed": "#d7e2ff",
                        "primary-container": "#508ff8",
                        "surface-tint": "#acc7ff",
                        "on-tertiary-fixed": "#2d1600",
                        "surface-dim": "#111319",
                        "on-primary-fixed-variant": "#004492",
                        "outline-variant": "#424753",
                        "surface-container-highest": "#33343b",
                        "on-error": "#690005",
                        "on-background": "#e2e2eb",
                        "surface-variant": "#33343b",
                        "on-secondary-container": "#a4b8e6",
                        "on-secondary": "#1a3055",
                        "inverse-primary": "#005bbf"
                    },
                    borderRadius: {
                        DEFAULT: "0.25rem",
                        lg: "0.5rem",
                        xl: "0.75rem",
                        full: "9999px"
                    },
                    fontFamily: {
                        headline: ["Inter"],
                        body: ["Inter"],
                        label: ["Inter"]
                    }
                }
            }
        };
    </script>
    <style>
        body { font-family: 'Inter', sans-serif; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        .glass-panel { background: rgba(51, 52, 59, 0.8); backdrop-filter: blur(24px); }
    </style>
</head>
<body class="bg-background text-on-surface selection:bg-primary-container selection:text-on-primary-container">
    <nav class="fixed top-0 w-full z-50 bg-[#111319]/80 backdrop-blur-xl transition-all">
        <div class="flex justify-between items-center px-6 py-4 max-w-7xl mx-auto">
            <div class="flex items-center gap-8">
                <a class="text-xl font-bold tracking-tighter text-slate-50 font-sans Inter" href="/Home">CodeGraph</a>
                <div class="hidden md:flex gap-6">
                    <a class="text-blue-400 font-semibold font-sans Inter tracking-tight" href="#">Platform</a>
                    <a asp-controller="Home" asp-action="Solutions" class="text-slate-400 hover:text-slate-100 transition-colors duration-200 font-sans Inter tracking-tight">Çözümler</a>
                </div>
            </div>
            <div class="flex items-center gap-4">
                <a asp-controller="Account" asp-action="Login" class="text-slate-400 hover:text-slate-100 transition-colors duration-200 font-sans Inter text-sm font-medium scale-95 active:opacity-80">Giriş Yap</a>
                <a asp-controller="Account" asp-action="Register" class="bg-primary-container text-on-primary-container px-5 py-2 rounded-lg font-bold text-sm scale-95 active:opacity-80 transition-all hover:brightness-110">Hemen Başla</a>
            </div>
        </div>
    </nav>

    <header class="relative pt-32 pb-20 overflow-hidden">
        <div class="absolute inset-0 z-0 pointer-events-none">
            <div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-primary/10 rounded-full blur-[120px]"></div>
            <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-secondary/5 rounded-full blur-[100px]"></div>
        </div>
        <div class="relative z-10 max-w-7xl mx-auto px-6 text-center">
            <span class="inline-block px-4 py-1.5 mb-6 text-xs font-bold tracking-widest text-primary uppercase bg-primary/10 rounded-full border border-primary/20">Sistem Zekası 2.0</span>
            <h1 class="text-5xl md:text-7xl font-extrabold tracking-tighter text-on-surface mb-6 max-w-4xl mx-auto leading-[1.1]">
                Yazılım Ekosisteminize <span class="bg-gradient-to-r from-primary via-secondary to-primary bg-clip-text text-transparent">Tam Hakimiyet Sağlayın</span>
            </h1>
            <p class="text-xl text-on-surface-variant mb-10 max-w-2xl mx-auto font-medium">
                Mimari kör noktaları ortadan kaldırın. Karmaşık bağımlılık haritalarını görselleştirin ve kritik riskleri üretime ulaşmadan önce tespit edin.
            </p>
            <div class="flex flex-col sm:flex-row justify-center gap-4">
                <a asp-controller="Account" asp-action="Register" class="bg-gradient-to-br from-primary-container to-primary text-on-primary px-8 py-4 rounded-xl font-bold text-lg shadow-xl shadow-primary/20 transition-all hover:scale-105 active:scale-95">Ücretsiz Başlayın</a>
                <a href="mailto:ozlemkilic101@gmail.com?subject=CodeGraph%20Demo%20Talebi" class="bg-surface-container-highest border border-outline-variant/30 text-on-surface px-8 py-4 rounded-xl font-bold text-lg transition-all hover:bg-surface-container-high active:scale-95">Demo Talep Et</a>
            </div>
        </div>
    </header>

    <section class="py-12 bg-surface-container-low/50">
        <div class="max-w-7xl mx-auto px-6 text-center">
            <p class="text-xs font-bold tracking-widest text-on-surface-variant uppercase mb-8">İleri görüşlü şirketlerdeki güvenlik ekiplerinin tercihi</p>
            <div class="flex flex-wrap justify-center items-center gap-12 opacity-50 grayscale contrast-125">
                <span class="text-2xl font-black text-on-surface">VOYAGER</span>
                <span class="text-2xl font-black text-on-surface">QUANTUM</span>
                <span class="text-2xl font-black text-on-surface">SYNTHETIX</span>
                <span class="text-2xl font-black text-on-surface">NEBULA.IO</span>
                <span class="text-2xl font-black text-on-surface">VECTOR</span>
            </div>
        </div>
    </section>

    <section class="py-24 max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
            <div class="md:col-span-8 bg-surface-container rounded-3xl p-10 border border-outline-variant/10 relative overflow-hidden group">
                <div class="relative z-10">
                    <span class="material-symbols-outlined text-primary text-4xl mb-6">hub</span>
                    <h3 class="text-3xl font-bold text-on-surface mb-4">Derin Bağımlılık Analizi</h3>
                    <p class="text-on-surface-variant text-lg max-w-md">Zincirinizdeki her halkayı görünür hale getirin. Özyinelemeli motorumuz, depolar ve diller arasında çok katmanlı bağımlılıkları haritalar.</p>
                </div>
                <div class="absolute right-0 bottom-0 w-1/2 h-full opacity-30 group-hover:opacity-50 transition-opacity">
                    <img class="w-full h-full object-cover object-left-top" alt="Karanlık bir teknik arka planda eğrisel çizgilerle birbirine bağlanan parlak düğümler" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDJ1AMRCPd_P9D0NA7BSfTcaCWDdRGqlVE6Y9fguyAktSPZRhRF1GeCGNiDnSFBilzF7pXXYpXgRyV0cdP5zZ2pggX86rg33nUMXZO3LeHsNjA3GF8Mx1Ycg_F3rvgIejK0Q689Iv4TclyYyAmYdc-VNB5m68KIO4Ck2eIz-bhKHx_wNILw032xnszV-VGXK-jbgT7tCnvTXXSGingAKCr6OgDQo-tNM6jhFI_WDXqFeC5ywYehv6GaaxPM1W-ou2oDIImk7IHL7fjH" />
                </div>
            </div>

            <div class="md:col-span-4 bg-surface-container-highest rounded-3xl p-10 border border-outline-variant/10 flex flex-col justify-between">
                <div>
                    <span class="material-symbols-outlined text-error text-4xl mb-6" style="font-variation-settings: 'FILL' 1;">security</span>
                    <h3 class="text-2xl font-bold text-on-surface mb-4">Yapay Zeka Destekli Risk Tespiti</h3>
                    <p class="text-on-surface-variant">Zafiyetleri ve güncel olmayan paketleri, kritik tehditlere dönüşmeden önce belirleyin.</p>
                </div>
                <div class="mt-8 pt-8 border-t border-outline-variant/20">
                    <div class="flex items-center gap-3 text-error">
                        <span class="w-2 h-2 rounded-full bg-error animate-pulse"></span>
                        <span class="text-sm font-bold uppercase tracking-tighter">Canlı Tehdit Akışı</span>
                    </div>
                </div>
            </div>

            <div class="md:col-span-4 bg-surface-container-low rounded-3xl p-10 border border-outline-variant/10">
                <span class="material-symbols-outlined text-tertiary text-4xl mb-6">group</span>
                <h3 class="text-2xl font-bold text-on-surface mb-4">Ekip Katkı İçgörüleri</h3>
                <p class="text-on-surface-variant">Proje güvenliğinde bireysel etkiyi anlayın, kurum genelinde kod tabanı sağlığını koruyun.</p>
            </div>

            <div class="md:col-span-8 bg-surface-container rounded-3xl p-1 relative overflow-hidden">
                <div class="bg-surface-dim rounded-[22px] h-full p-10 border border-outline-variant/5">
                    <div class="flex flex-col md:flex-row gap-8 items-center">
                        <div class="flex-1">
                            <h3 class="text-2xl font-bold text-on-surface mb-4">Doğal CI/CD Entegrasyonu</h3>
                            <p class="text-on-surface-variant">CodeGraph'ı GitHub Actions, GitLab CI veya Jenkins'e sorunsuzca bağlayın. Her pull request için güvenlik denetimlerini otomatikleştirin.</p>
                        </div>
                        <div class="flex gap-4">
                            <div class="w-12 h-12 rounded-xl bg-surface-container-highest flex items-center justify-center border border-outline-variant/20">
                                <span class="material-symbols-outlined text-on-surface-variant">terminal</span>
                            </div>
                            <div class="w-12 h-12 rounded-xl bg-surface-container-highest flex items-center justify-center border border-outline-variant/20">
                                <span class="material-symbols-outlined text-on-surface-variant">settings_ethernet</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="py-24 bg-surface-container-lowest">
        <div class="max-w-7xl mx-auto px-6">
            <div class="text-center mb-16">
                <h2 class="text-4xl font-bold text-on-surface tracking-tight mb-4">Kodunuza Yeni Bir Boyuttan Bakın</h2>
                <p class="text-on-surface-variant max-w-xl mx-auto">CodeGraph paneli, yoğun kayıt verilerini etkileyici görselleştirmelerle aksiyona dönüştürülebilir içgörülere çevirir.</p>
            </div>
            <div class="relative max-w-5xl mx-auto rounded-2xl overflow-hidden shadow-2xl shadow-black/60 border border-outline-variant/20">
                <div class="bg-surface-container-high px-4 py-3 border-b border-outline-variant/30 flex items-center gap-2">
                    <div class="flex gap-1.5">
                        <div class="w-3 h-3 rounded-full bg-error/40"></div>
                        <div class="w-3 h-3 rounded-full bg-tertiary/40"></div>
                        <div class="w-3 h-3 rounded-full bg-primary/40"></div>
                    </div>
                    <div class="ml-4 bg-surface-container-lowest px-3 py-1 rounded text-[10px] font-mono text-on-surface-variant uppercase tracking-widest">codegraph-cloud-inspector</div>
                </div>
                <div class="aspect-video relative bg-[#0c0e14]">
                    <img class="w-full h-full object-cover" alt="Mavi ve turuncu vurgularla yüksek teknoloji yazılım paneli görünümü" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDBY0mUooCYeoatZxvuPyCtwO_9pwdGtmpmSlJTsuk1_Gtm7tkq-r1f6wKsl6jZz0CIc4G3Ht6hnLJZmHmqqTrQ8woo324TW5So-Vsh_yOCqQRi-FUyAh8-vcdkflV7xwkfQQ2ddVDkk6jV3z1c6yoY5MtmpB2T72ixnvGS-TFTzNnn2xPqWBRqKfAVtgR0McLED4OXgs0lJRWh6xPwIjs1xhzj7VRdYmg-w2_nqodLsT1M3GUBWv70tHbiIq7ZHVIblYxPDd-SCP6_" />

                    <div class="absolute top-10 left-10 glass-panel p-6 rounded-2xl border border-white/5 w-64 shadow-xl">
                        <p class="text-[10px] font-bold text-primary uppercase mb-2 tracking-widest">Sistem Sağlığı</p>
                        <div class="text-3xl font-bold text-on-surface mb-1">98.4%</div>
                        <div class="w-full bg-surface-container-highest h-1 rounded-full overflow-hidden">
                            <div class="w-4/5 h-full bg-primary"></div>
                        </div>
                    </div>

                    <div class="absolute bottom-10 right-10 glass-panel p-6 rounded-2xl border border-white/5 w-72 shadow-xl">
                        <p class="text-[10px] font-bold text-tertiary uppercase mb-2 tracking-widest">Aktif Riskler</p>
                        <div class="space-y-3">
                            <div class="flex justify-between items-center bg-surface-container-low p-2 rounded-lg">
                                <span class="text-xs text-on-surface">lodash@4.17.21</span>
                                <span class="text-[10px] font-bold text-error px-2 py-0.5 rounded bg-error/10">KRİTİK</span>
                            </div>
                            <div class="flex justify-between items-center bg-surface-container-low p-2 rounded-lg opacity-60">
                                <span class="text-xs text-on-surface">axios@1.6.2</span>
                                <span class="text-[10px] font-bold text-tertiary px-2 py-0.5 rounded bg-tertiary/10">ORTA</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="py-32 relative overflow-hidden">
        <div class="absolute inset-0 bg-primary/5"></div>
        <div class="max-w-4xl mx-auto px-6 text-center relative z-10">
            <h2 class="text-4xl md:text-5xl font-extrabold text-on-surface mb-8 tracking-tighter">Kod tabanınızı güvenceye almaya hazır mısınız?</h2>
            <p class="text-xl text-on-surface-variant mb-12">2.000+ mühendislik ekibiyle birlikte daha güvenli yazılıma giden yolu haritalayın.</p>
            <div class="flex flex-col sm:flex-row justify-center gap-6">
                <a asp-controller="Account" asp-action="Register" class="bg-primary text-on-primary px-10 py-5 rounded-2xl font-bold text-xl transition-all hover:brightness-110 hover:shadow-2xl hover:shadow-primary/30">Hemen Başlayın</a>
                <a href="mailto:ozlemkilic101@gmail.com?subject=CodeGraph%20Demo%20Talebi" class="text-on-surface-variant font-bold hover:text-on-surface transition-colors flex items-center justify-center gap-2">
                    Bir Uzmanla Görüşün <span class="material-symbols-outlined">arrow_forward</span>
                </a>
            </div>
        </div>
    </section>

    <footer class="bg-[#111319] border-t border-slate-800/50 w-full py-12 px-6">
        <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6">
            <div class="flex flex-col items-center md:items-start gap-2">
                <span class="text-lg font-bold text-slate-200">CodeGraph</span>
                <p class="text-slate-500 text-sm">© 2026 CodeGraph. Tüm hakları saklıdır.</p>
            </div>
            <div class="flex flex-wrap justify-center gap-8">
                <a class="text-slate-500 hover:text-slate-200 transition-colors opacity-100 hover:opacity-80 text-sm" href="#">Gizlilik Politikası</a>
                <a class="text-slate-500 hover:text-slate-200 transition-colors opacity-100 hover:opacity-80 text-sm" href="#">Kullanım Şartları</a>
                <a class="text-slate-500 hover:text-slate-200 transition-colors opacity-100 hover:opacity-80 text-sm" href="#">Güvenlik</a>
                <a class="text-slate-500 hover:text-slate-200 transition-colors opacity-100 hover:opacity-80 text-sm" href="#">Durum</a>
                <a class="text-slate-500 hover:text-slate-200 transition-colors opacity-100 hover:opacity-80 text-sm" href="#">İletişim</a>
            </div>
        </div>
    </footer>
</body>
</html>
