@model CodeGraphWeb.ViewModels.Admin.AdminUsersViewModel
@using CodeGraphWeb.Constants
@{
    ViewData["Title"] = "Admin Paneli";
}

<section class="space-y-6">
    <div>
        <h1 class="text-3xl font-black tracking-tight">Kullanici ve Rol Yonetimi</h1>
        <p class="text-on-surface-variant mt-1">Rol, sirket, kullanici bilgisi ve sifre sifirlama islemleri.</p>
    </div>

    @if (TempData["RoleError"] is string roleError)
    {
        <div class="rounded-lg border border-red-400/30 bg-red-400/10 text-red-200 px-4 py-3 text-sm">@roleError</div>
    }

    @if (TempData["RoleSuccess"] is string roleSuccess)
    {
        <div class="rounded-lg border border-emerald-400/30 bg-emerald-400/10 text-emerald-200 px-4 py-3 text-sm">@roleSuccess</div>
    }

    @if (Model.CompanyGroups.Count == 0)
    {
        <div class="bg-surface-container rounded-xl border border-white/10 p-6 text-sm text-on-surface-variant">
            Gosterilecek kullanici bulunamadi.
        </div>
    }
    else
    {
        @foreach (var group in Model.CompanyGroups)
        {
            <section class="bg-surface-container rounded-xl border border-white/10 overflow-hidden">
                <div class="px-5 py-4 border-b border-white/10 bg-surface-container-high">
                    <h3 class="text-lg font-bold">@group.CompanyName</h3>
                    <p class="text-xs text-on-surface-variant mt-1">Kullanici sayisi: @group.Users.Count</p>
                </div>

                <div class="overflow-x-auto">
                    <table class="min-w-full text-sm">
                        <thead class="text-on-surface-variant uppercase text-xs tracking-wider">
                            <tr>
                                <th class="px-4 py-3 text-left">Kullanici</th>
                                <th class="px-4 py-3 text-left">Rol</th>
                                @if (Model.IsSystemAdmin)
                                {
                                    <th class="px-4 py-3 text-left">Sirket</th>
                                }
                                <th class="px-4 py-3 text-left">Hizli Islem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in group.Users)
                            {
                                <tr class="border-t border-white/5 align-top">
                                    <td class="px-4 py-3">
                                        <div class="font-semibold">@user.FullName</div>
                                        <div class="text-on-surface-variant text-xs">@user.Email</div>
                                    </td>
                                    <td class="px-4 py-3">
                                        @if (user.CurrentRole == Roles.SystemAdmin)
                                        {
                                            <span class="text-xs font-semibold text-on-surface-variant">SystemAdmin</span>
                                        }
                                        else
                                        {
                                            <form asp-controller="Admin" asp-action="AssignRole" method="post" class="flex items-center gap-2">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="UserId" value="@user.UserId" />
                                                <select name="Role" class="bg-surface-container-high rounded-md border border-white/10 px-3 py-2 text-xs">
                                                    @foreach (var role in Model.AvailableRoles)
                                                    {
                                                        if (role == user.CurrentRole)
                                                        {
                                                            <option value="@role" selected>@role</option>
                                                        }
                                                        else
                                                        {
                                                            <option value="@role">@role</option>
                                                        }
                                                    }
                                                </select>
                                                <button type="submit" class="bg-primary-container text-on-primary px-3 py-2 rounded-md text-xs font-semibold">Guncelle</button>
                                            </form>
                                        }
                                    </td>
                                    @if (Model.IsSystemAdmin)
                                    {
                                        <td class="px-4 py-3">
                                            @if (user.CurrentRole == Roles.SystemAdmin)
                                            {
                                                <span class="text-xs text-on-surface-variant">Sabit</span>
                                            }
                                            else
                                            {
                                                <form asp-controller="Admin" asp-action="AssignCompany" method="post" class="flex items-center gap-2">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="UserId" value="@user.UserId" />
                                                    <select name="CompanyId" class="bg-surface-container-high rounded-md border border-white/10 px-3 py-2 text-xs">
                                                        @foreach (var company in Model.AvailableCompanies)
                                                        {
                                                            if (user.CompanyId == company.Id)
                                                            {
                                                                <option value="@company.Id" selected>@company.Name</option>
                                                            }
                                                            else
                                                            {
                                                                <option value="@company.Id">@company.Name</option>
                                                            }
                                                        }
                                                    </select>
                                                    <button type="submit" class="bg-surface-container-high text-on-surface px-3 py-2 rounded-md text-xs font-semibold">Kaydet</button>
                                                </form>
                                            }
                                        </td>
                                    }
                                    <td class="px-4 py-3">
                                        @if (user.CurrentRole == Roles.SystemAdmin && !Model.IsSystemAdmin)
                                        {
                                            <span class="text-xs text-on-surface-variant">Yetki yok</span>
                                        }
                                        else
                                        {
                                            <details>
                                                <summary class="cursor-pointer text-xs text-primary font-semibold">Bilgi / Sifre Guncelle</summary>
                                                <form asp-controller="Admin" asp-action="UpdateUser" method="post" class="mt-2 space-y-2 min-w-[260px]">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="UserId" value="@user.UserId" />
                                                    <input type="text" name="FullName" value="@user.FullName" class="w-full bg-surface-container-high rounded-md border border-white/10 px-3 py-2 text-xs" placeholder="Ad Soyad" />
                                                    <input type="email" name="Email" value="@user.Email" class="w-full bg-surface-container-high rounded-md border border-white/10 px-3 py-2 text-xs" placeholder="E-posta" />
                                                    <input type="password" name="NewPassword" class="w-full bg-surface-container-high rounded-md border border-white/10 px-3 py-2 text-xs" placeholder="Yeni sifre (opsiyonel)" />
                                                    <button type="submit" class="bg-primary-container text-on-primary px-3 py-2 rounded-md text-xs font-semibold">Kaydet</button>
                                                </form>
                                            </details>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }
    }
</section>
