@model CodeGraphWeb.ViewModels.Admin.AdminUsersViewModel
@using CodeGraphWeb.Constants
@{
    ViewData["Title"] = "Admin Paneli";
}

<section class="space-y-6">
    <div>
        <h1 class="text-3xl font-black tracking-tight">Kullanıcı Rol Yönetimi</h1>
        <p class="text-on-surface-variant mt-1">
            Yeni Rol seçenekleri: @string.Join(" / ", Model.AvailableRoles)
        </p>
        @if (Model.IsSystemAdmin)
        {
            <p class="text-xs text-on-surface-variant mt-2">SystemAdmin gorunumu: kullanicilar sirket bazinda gruplanmistir.</p>
        }
    </div>

    @if (TempData["RoleError"] is string roleError)
    {
        <div class="rounded-lg border border-red-400/30 bg-red-400/10 text-red-200 px-4 py-3 text-sm">@roleError</div>
    }

    @if (TempData["RoleSuccess"] is string roleSuccess)
    {
        <div class="rounded-lg border border-emerald-400/30 bg-emerald-400/10 text-emerald-200 px-4 py-3 text-sm">@roleSuccess</div>
    }

    @if (Model.CompanyGroups.Count == 0)
    {
        <div class="bg-surface-container rounded-xl border border-white/10 p-6 text-sm text-on-surface-variant">
            Gösterilecek kullanıcı bulunamadı.
        </div>
    }
    else
    {
        @foreach (var group in Model.CompanyGroups)
        {
            <section class="bg-surface-container rounded-xl border border-white/10 overflow-hidden">
                <div class="px-5 py-4 border-b border-white/10 bg-surface-container-high">
                    <h3 class="text-lg font-bold">@group.CompanyName</h3>
                    <p class="text-xs text-on-surface-variant mt-1">Kullanıcı sayısı: @group.Users.Count</p>
                </div>

                <div class="overflow-x-auto">
                    <table class="min-w-full text-sm">
                        <thead class="text-on-surface-variant uppercase text-xs tracking-wider">
                            <tr>
                                <th class="px-4 py-3 text-left">Ad Soyad</th>
                                <th class="px-4 py-3 text-left">E-posta</th>
                                <th class="px-4 py-3 text-left">Mevcut Rol</th>
                                <th class="px-4 py-3 text-left">Yeni Rol</th>
                                <th class="px-4 py-3 text-left">İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in group.Users)
                            {
                                <tr class="border-t border-white/5">
                                    <td class="px-4 py-3">@user.FullName</td>
                                    <td class="px-4 py-3 text-on-surface-variant">@user.Email</td>
                                    <td class="px-4 py-3 text-on-surface-variant">@user.CurrentRole</td>
                                    <td class="px-4 py-3" colspan="2">
                                        @if (user.CurrentRole == Roles.SystemAdmin)
                                        {
                                            <span class="text-xs font-semibold text-on-surface-variant">SystemAdmin rolu panelden degistirilemez.</span>
                                        }
                                        else
                                        {
                                            <form asp-controller="Admin" asp-action="AssignRole" method="post" class="flex items-center gap-3">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="UserId" value="@user.UserId" />
                                                <select name="Role" class="bg-surface-container-high rounded-md border border-white/10 px-3 py-2">
                                                    @foreach (var role in Model.AvailableRoles)
                                                    {
                                                        if (role == user.CurrentRole)
                                                        {
                                                            <option value="@role" selected>@role</option>
                                                        }
                                                        else
                                                        {
                                                            <option value="@role">@role</option>
                                                        }
                                                    }
                                                </select>
                                                <button type="submit" class="bg-primary-container text-on-primary px-3 py-2 rounded-md font-semibold">Güncelle</button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }
    }
</section>

