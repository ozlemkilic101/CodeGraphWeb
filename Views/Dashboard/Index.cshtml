@model CodeGraphWeb.ViewModels.DashboardViewModel
@using CodeGraphWeb.Constants
@{
    ViewData["Title"] = "Dashboard";
}

<section class="space-y-6">
    <div class="bg-surface-container rounded-xl border border-white/10 p-6">
        <h2 class="text-2xl font-extrabold">Dashboard</h2>
        <p class="text-on-surface-variant mt-2">@Model.WelcomeMessage</p>
    </div>

    @if (Model.Role == Roles.SystemAdmin)
    {
        @await Html.PartialAsync("Partials/_SuperAdminDashboard", Model)
    }
    else if (Model.Role == Roles.CompanyAdmin)
    {
        @await Html.PartialAsync("Partials/_AdminDashboard", Model)
    }
    else if (Model.Role == Roles.TechLead || Model.ProjectRole == ProjectRoles.TechLead)
    {
        @await Html.PartialAsync("Partials/_TechLeadDashboard", Model)
    }
    else
    {
        @await Html.PartialAsync("Partials/_DeveloperDashboard", Model)
    }
</section>
