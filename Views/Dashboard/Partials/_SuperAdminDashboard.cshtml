@model CodeGraphWeb.ViewModels.DashboardViewModel

<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <article class="bg-surface-container p-6 rounded-xl border border-white/10">
        <p class="text-sm text-on-surface-variant">Toplam Sirket</p>
        <h3 class="text-3xl font-bold mt-1">@Model.TotalCompanies</h3>
    </article>
    <article class="bg-surface-container p-6 rounded-xl border border-white/10">
        <p class="text-sm text-on-surface-variant">Toplam Kullanici</p>
        <h3 class="text-3xl font-bold mt-1">@Model.TotalUsers</h3>
    </article>
    <article class="bg-surface-container p-6 rounded-xl border border-white/10">
        <p class="text-sm text-on-surface-variant">Yonetilen Proje Sayisi</p>
        <h3 class="text-3xl font-bold mt-1">@Model.TotalProjects</h3>
    </article>
</div>

<section class="bg-surface-container rounded-xl border border-white/10 p-6 mt-6">
    <div class="flex items-center justify-between mb-4">
        <h4 class="text-lg font-bold">Company Management</h4>
        <div class="flex gap-2">
            <a asp-controller="Company" asp-action="Create" class="bg-primary-container text-on-primary px-4 py-2 rounded-md font-semibold">Create Company</a>
            <a asp-controller="Admin" asp-action="Users" class="bg-surface-container-high text-on-surface px-4 py-2 rounded-md font-semibold">Role Management</a>
        </div>
    </div>

    @if (Model.CompanyGroups.Count == 0)
    {
        <p class="text-on-surface-variant text-sm">Sirket verisi bulunamadi.</p>
    }
    else
    {
        <div class="space-y-3">
            @foreach (var company in Model.CompanyGroups)
            {
                <details class="bg-surface-container-high rounded-lg border border-white/5" open>
                    <summary class="px-4 py-3 cursor-pointer font-semibold flex items-center justify-between">
                        <span>@company.CompanyName</span>
                        <span class="text-xs text-on-surface-variant">@company.UserCount kullanici · @company.ProjectCount proje</span>
                    </summary>
                    <div class="px-4 pb-4">
                        @if (company.Users.Count == 0)
                        {
                            <p class="text-xs text-on-surface-variant">Kullanici bulunamadi.</p>
                        }
                        else
                        {
                            <ul class="space-y-2 text-sm">
                                @foreach (var user in company.Users)
                                {
                                    <li class="bg-surface-container-low rounded-md px-3 py-2 flex items-center justify-between">
                                        <div>
                                            <p class="font-semibold">@user.FullName</p>
                                            <p class="text-xs text-on-surface-variant">@user.Email</p>
                                        </div>
                                        <span class="text-xs px-2 py-1 rounded bg-primary/10 text-primary">@user.Role</span>
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                </details>
            }
        </div>
    }
</section>
