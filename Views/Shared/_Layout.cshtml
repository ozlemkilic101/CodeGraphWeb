<!DOCTYPE html>
<html class="dark" lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CodeGraph</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>

<body class="bg-gray-950 text-gray-200">

    <!-- Sidebar -->
    <aside class="h-screen w-64 fixed bg-gray-900 border-r border-gray-800 p-6">
        <h1 class="text-xl font-bold mb-10">CodeGraph</h1>

        <nav class="space-y-2">
            <a href="/Dashboard" class="block p-2 hover:bg-gray-800 rounded">Dashboard</a>
            <a href="/Project" class="block p-2 hover:bg-gray-800 rounded">Projects</a>
            <a href="/Company" class="block p-2 hover:bg-gray-800 rounded">Company</a>
        </nav>
    </aside>

    <!-- Main -->
    <main class="ml-64">

        <!-- Topbar -->
        <header class="h-16 bg-gray-900 border-b border-gray-800 flex items-center justify-between px-6">
            <h2 class="font-bold">Dashboard</h2>

            <div>
                <input type="text" placeholder="Search..." class="bg-gray-800 px-3 py-2 rounded" />
            </div>
        </header>

        <!-- Content -->
        <div class="p-6">
            @RenderBody()
        </div>

    </main>

</body>
</html>