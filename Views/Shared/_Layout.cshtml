@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentArea = ViewContext.RouteData.Values["area"]?.ToString() ?? string.Empty;
    string NavClass(string controller, string? area = null) =>
        string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase) &&
        string.Equals(currentArea, area ?? string.Empty, StringComparison.OrdinalIgnoreCase)
            ? "flex items-center gap-3 px-4 py-3 text-blue-400 bg-blue-500/10 border-r-2 border-blue-500 transition-all duration-200"
            : "flex items-center gap-3 px-4 py-3 text-slate-400 hover:text-slate-200 hover:bg-white/5 transition-all duration-200";
}
@using CodeGraphWeb.Constants
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager

<!DOCTYPE html>
<html class="dark" lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] is null ? "CodeGraph" : $"{ViewData["Title"]} | CodeGraph")</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "on-surface": "#e2e2eb",
                        "surface-dim": "#111319",
                        "surface-container-low": "#191b22",
                        "surface-container-lowest": "#0c0e14",
                        "surface-container": "#1e1f26",
                        "surface-container-high": "#282a30",
                        "surface-container-highest": "#33343b",
                        "on-surface-variant": "#c2c6d5",
                        "outline": "#8c909e",
                        "outline-variant": "#424753",
                        "primary": "#acc7ff",
                        "primary-container": "#508ff8",
                        "on-primary": "#002f68",
                        "secondary": "#b2c7f5",
                        "tertiary": "#ffb873",
                        "error": "#ffb4ab"
                    },
                    fontFamily: {
                        body: ["Inter"]
                    }
                }
            }
        };
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-surface-dim text-on-surface font-body">
    <aside class="h-screen w-64 fixed left-0 top-0 overflow-y-auto bg-[#111319] flex flex-col py-6 border-r border-white/5 z-50">
        <div class="px-6 mb-10 flex items-center gap-3">
            <div class="w-8 h-8 rounded bg-primary-container flex items-center justify-center text-on-primary">
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">account_tree</span>
            </div>
            <div>
                <h1 class="text-lg font-bold text-slate-100">CodeGraph</h1>
                <p class="text-[10px] uppercase tracking-widest text-on-surface-variant font-semibold">Vulnerability Mapper</p>
            </div>
        </div>

                <nav class="flex-1">
            <a class="@NavClass("Home")" href="/Home">
                <span class="material-symbols-outlined">home</span>
                <span class="text-[13px] font-medium tracking-wide">Home</span>
            </a>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <a class="@NavClass("Dashboard")" href="/Dashboard">
                    <span class="material-symbols-outlined">dashboard</span>
                    <span class="text-[13px] font-medium tracking-wide">Dashboard</span>
                </a>
            }

            @if (User.IsInRole(Roles.SystemAdmin))
            {
                <a class="@NavClass("Company")" href="/Company">
                    <span class="material-symbols-outlined">domain</span>
                    <span class="text-[13px] font-medium tracking-wide">Companies</span>
                </a>
                <a class="@NavClass("Admin")" asp-controller="Admin" asp-action="Users">
                    <span class="material-symbols-outlined">admin_panel_settings</span>
                    <span class="text-[13px] font-medium tracking-wide">Users</span>
                </a>
            }

            @if (User.IsInRole(Roles.CompanyAdmin))
            {
                <a class="@NavClass("Project")" href="/Project">
                    <span class="material-symbols-outlined">account_tree</span>
                    <span class="text-[13px] font-medium tracking-wide">Projects</span>
                </a>
                <a class="@NavClass("Admin")" asp-controller="Admin" asp-action="Users">
                    <span class="material-symbols-outlined">groups</span>
                    <span class="text-[13px] font-medium tracking-wide">Team</span>
                </a>
            }

            @if (User.IsInRole(Roles.TechLead))
            {
                <a class="@NavClass("Project")" href="/Project">
                    <span class="material-symbols-outlined">account_tree</span>
                    <span class="text-[13px] font-medium tracking-wide">My Projects</span>
                </a>
            }

            @if (User.IsInRole(Roles.User))
            {
                <a class="@NavClass("Project")" href="/Project">
                    <span class="material-symbols-outlined">view_list</span>
                    <span class="text-[13px] font-medium tracking-wide">Assigned Projects</span>
                </a>
            }
        </nav>

        <div class="mt-auto border-t border-white/5 pt-4">
            <a class="flex items-center gap-3 px-4 py-3 text-slate-400 hover:text-slate-200 hover:bg-white/5 transition-all" href="#">
                <span class="material-symbols-outlined">contact_support</span>
                <span class="text-[13px] font-medium tracking-wide">Support</span>
            </a>
        </div>
    </aside>

    <main class="pl-64 min-h-screen">
        <header class="w-full h-16 sticky top-0 z-40 bg-[#111319] flex items-center justify-between px-6 border-b border-white/5 shadow-2xl shadow-black/40">
            <div class="flex items-center gap-6 flex-1">
                <h2 class="text-xl font-black tracking-tight text-slate-50">@ViewData["Title"]</h2>
                <div class="relative max-w-md w-full">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant text-sm">search</span>
                    <input class="w-full bg-surface-container-low border-none rounded-lg pl-10 pr-4 py-2 text-sm text-on-surface placeholder:text-outline focus:ring-2 focus:ring-primary/30" placeholder="Search vulnerabilities or projects..." type="text" />
                </div>
            </div>
            <div class="flex items-center gap-4">
                @if (SignInManager.IsSignedIn(User))
                {
                    <button class="w-10 h-10 flex items-center justify-center rounded-lg text-slate-400 hover:bg-slate-800/50 transition-colors duration-200">
                        <span class="material-symbols-outlined">notifications</span>
                    </button>
                    <div class="h-8 w-px bg-white/10"></div>
                    <div class="flex items-center gap-3 pl-2">
                        <div class="w-8 h-8 rounded-full bg-surface-container-highest border border-primary/20 flex items-center justify-center text-xs font-bold">
                            @(User.Identity?.Name?.Length > 0 ? User.Identity.Name[..1].ToUpperInvariant() : "U")
                        </div>
                        <span class="text-sm font-medium text-slate-200">@User.Identity?.Name</span>
                    </div>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="ml-2">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="text-sm font-semibold text-slate-300 hover:text-white transition-colors">
                            Logout
                        </button>
                    </form>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="text-sm font-semibold text-slate-300 hover:text-white transition-colors">
                        Login
                    </a>
                    <a asp-controller="Account" asp-action="Register" class="text-sm font-semibold bg-primary-container text-on-primary px-4 py-2 rounded-lg hover:brightness-110 transition">
                        Register
                    </a>
                }
            </div>
        </header>
        <div class="max-w-7xl mx-auto p-8">
            @RenderBody()
        </div>
    </main>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>


